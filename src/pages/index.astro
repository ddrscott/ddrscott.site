---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const withImages = sorted.filter((e) => e.data.image);
const latest = withImages.slice(0, 12);
---
<Base
  title="Why, Scott, WHY?!?"
  description="Personal tech blog by Scott Pierce. SQL, Vim, Ruby, and tools for problems no one thinks they have."
  wide={true}
>
  <h1>Latest Posts</h1>
  <p class="text-muted">
    Posts and projects cataloging a developer's history in the field.
    See the full <a href="/archive/">archive</a> for everything ever written.
  </p>
  <div class="post-grid">
    {latest.map((entry) => <PostCard entry={entry} />)}
  </div>
</Base>
