---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const byYear = new Map<string, typeof sorted>();
for (const entry of sorted) {
  const year = entry.data.year;
  const bucket = byYear.get(year) ?? [];
  bucket.push(entry);
  byYear.set(year, bucket);
}
const years = [...byYear.keys()].sort().reverse();
---
<Base title="Archive" description="Every post Scott has written, by year.">
  <h1>Archive</h1>
  <p class="text-muted">{sorted.length} posts. <a href="/llms.txt">llms.txt</a> · <a href="/llms-full.txt">llms-full.txt</a> · <a href="/rss.xml">RSS</a></p>

  {years.map((year) => (
    <section class="archive-year">
      <h2 class="archive-year__heading">{year}</h2>
      <ul class="archive-list">
        {byYear.get(year)!.map((entry) => {
          const dateStr = entry.data.date.toISOString().slice(0, 10);
          return (
            <li>
              <time datetime={dateStr}>{dateStr}</time>
              <a href={`/blog/${entry.data.year}/${entry.data.slug}/`}>{entry.data.title}</a>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</Base>
